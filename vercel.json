{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/getUsers", "dest": "/api/getUsers.js" },
    { "src": "/api/send", "dest": "/api/send.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
